<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="exemplo-visitas"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">
    <parameter name="dataInicio" class="java.lang.String"/>
    <parameter name="dataFim" class="java.lang.String"/>
    <field name="id" class="java.lang.Integer"/>
    <field name="titulo" class="java.lang.String"/>
    <field name="data_referencia" class="java.sql.Date"/>
    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Relatorio de Visitas - Exemplo]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="35" width="555" height="20"/>
                <textFieldExpression><![CDATA["Periodo: " + $P{dataInicio} + " ate " + $P{dataFim}]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="80" height="20"/>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="80" y="0" width="300" height="20"/>
                <text><![CDATA[Titulo]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="175" height="20"/>
                <text><![CDATA[Data]]></text>
            </staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="80" height="20"/>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80" y="0" width="300" height="20"/>
                <textFieldExpression><![CDATA[$F{titulo}]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="380" y="0" width="175" height="20"/>
                <textFieldExpression><![CDATA[$F{data_referencia}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
