	<variable name="PERIODO_RELATORIO" class="java.lang.String">
		<variableExpression><![CDATA[($P{dataInicial} == null || $P{dataInicial}.trim().isEmpty()) && ($P{dataFinal} == null || $P{dataFinal}.trim().isEmpty())
                ? "Todo o período"
                : (
                    ($P{dataInicial} != null && !$P{dataInicial}.trim().isEmpty() && $P{dataFinal} != null && !$P{dataFinal}.trim().isEmpty())
                        ? new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.text.SimpleDateFormat("yyyy-MM-dd").parse($P{dataInicial}.substring(0, 10)))
                          + " a "
                          + new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.text.SimpleDateFormat("yyyy-MM-dd").parse($P{dataFinal}.substring(0, 10)))
                        : (
                            ($P{dataInicial} != null && !$P{dataInicial}.trim().isEmpty())
                                ? "A partir de " + new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.text.SimpleDateFormat("yyyy-MM-dd").parse($P{dataInicial}.substring(0, 10)))
                                : "Até " + new java.text.SimpleDateFormat("dd/MM/yyyy").format(new java.text.SimpleDateFormat("yyyy-MM-dd").parse($P{dataFinal}.substring(0, 10)))
                          )
                  )]]></variableExpression>
	</variable>
	<variable name="FILTROS_APLICADOS" class="java.lang.String">
		<variableExpression><![CDATA[($P{idTecnico} == null && $P{idProjeto} == null)
                ? "Nenhum filtro adicional"
                : ($P{idTecnico} != null ? "Técnico ID: " + $P{idTecnico} : "")
                  + ($P{idTecnico} != null && $P{idProjeto} != null ? " | " : "")
                  + ($P{idProjeto} != null ? "Projeto ID: " + $P{idProjeto} : "")]]></variableExpression>
	</variable>
